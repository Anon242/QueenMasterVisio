<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="Ribbon_Load">
	<ribbon>
		<tabs>
			<tab id="MyTab2" label="Queen мастер">
				<group id="MyGroup6" label="Создание">
					<button id="btnCreatePlan" label="Создать план" size="normal" onAction="OnButtonClickDevice" imageMso="ZoomOnePage"/>
					<button id="btnUpdatePage" label="Обновить страницу" size="normal" onAction="OnButtonClickDevice" imageMso="AutoFormatChange"/>

					<button id="btnCreateNewDevice" label="Создать новый девайс" size="large" onAction="OnButtonClickDevice" imageMso="OrganizationChartSelectLevel"/>

				</group>
				<group id="MyGroup61" label="Блокировка">
					<button id="btnLock" label="Lock/Unlock страницу" size="large" onAction="OnButtonClickDevice" imageMso="ColumnActionsReadOnly"/>
				</group>
				<group id="MyGroup62" label="Копирование">
					<button id="btnCopyAll" label="Скопировать страницу" size="large" onAction="OnButtonClickDevice" imageMso="Copy"/>
					<button id="btnPasteAll" label="Вставить все на страницу" size="large" onAction="OnButtonClickDevice" imageMso="Paste"/>
				</group>
				<group id="MyGroup63" label="Настройки">

				</group>
				<group id="MyGroup64" label="Информация">
					<button id="btnLookDevices" label="Показать устройства" size="large" onAction="OnButtonClickDevice" imageMso="CustomizeMySite"/>
					<button id="btnLookDevicesOnPlan" label="Проверить страницу" size="large" onAction="OnButtonClickDevice" imageMso="CustomizeMySite"/>
				</group>
				<group id="MyGroup553" label="Инструменты">
					<!-- Указатель -->
					<control idMso="PointerTool" size="large"/>
					<!-- Линия -->
					<control idMso="ConnectorTool" size="large"/>
					<!-- Прямоугольник -->
					<control idMso="RectangleTool" size="large"/>
					<!-- Текст -->
					<control idMso="TextTool" size="large"/>
					
					<control idMso="LineColorGallery" size="normal"/>
					<!-- Толщина линии (работает в Visio) -->
					<control idMso="LineWeightGallery" size="normal"/>
					<!-- Тип линии (пунктир и т.д.) -->
					<control idMso="LinePatternGallery" size="normal"/>
				</group>
			</tab>
			<tab id="MyTab" label="План трассеров" getVisible="GetTabVisible">
				<group id="MyGroup2" label="Слои">
					<box id="btnGroup" boxStyle="horizontal">
						<button getLabel="GetLayerButtonLabel"  id="btnPlan"  size="large" onAction="OnButtonClickPlan" imageMso="DesignMode"/>
            <button getLabel="GetLayerButtonLabel"  id="btnPx" size="large" onAction="OnButtonClickPlan" imageMso="ShapeLightningBolt"/>
            <button getLabel="GetLayerButtonLabel"  id="btnEx" size="large" onAction="OnButtonClickPlan" imageMso="QuickPartsInsertFromOnline"/>
            <button getLabel="GetLayerButtonLabel"  id="btnRx" size="large" onAction="OnButtonClickPlan" imageMso="OrganizationChartSelectAllConnectors"/>
            <button getLabel="GetLayerButtonLabel"  id="btnDx" size="large" onAction="OnButtonClickPlan" imageMso="AutoFormatChange"/>
            <button getLabel="GetLayerButtonLabel"  id="btnCx" size="large" onAction="OnButtonClickPlan" imageMso="OrganizationChartAutoLayout"/>
            <button getLabel="GetLayerButtonLabel"  id="btnSx" size="large" onAction="OnButtonClickPlan" imageMso="FileCheckIn"/>
            <button getLabel="GetLayerButtonLabel"  id="btnYx" size="large" onAction="OnButtonClickPlan" imageMso="ReviewReplyWithChanges"/>
            <button getLabel="GetLayerButtonLabel"  id="btnVx" size="large" onAction="OnButtonClickPlan" imageMso="RecordsSaveRecord"/>
            <button getLabel="GetLayerButtonLabel"  id="btnLx" size="large" onAction="OnButtonClickPlan" imageMso="_3DLightingClassic"/>
            <button getLabel="GetLayerButtonLabel"  id="btnAx" size="large" onAction="OnButtonClickPlan" imageMso="NewContact"/>
            <button getLabel="GetLayerButtonLabel"  id="btnOther_1"  size="large" onAction="OnButtonClickPlan" imageMso="RightToLeftDocument"/>
            <button getLabel="GetLayerButtonLabel"  id="btnOther_2"  size="large" onAction="OnButtonClickPlan" imageMso="HeaderFooterPageNumberInsert"/>
            <button getLabel="GetLayerButtonLabel"  id="btnAll"  size="large" onAction="OnButtonClickPlan" imageMso="CategorizeMenu"/>
					</box>
				</group>
				<group id="MyGroup3" label="Инструменты">
					<!-- Указатель -->
					<control idMso="PointerTool" size="large"/>
					<!-- Линия -->
					<control idMso="ConnectorTool" size="large"/>
					<!-- Прямоугольник -->
					<control idMso="RectangleTool" size="large"/>
					<!-- Текст -->
					<control idMso="TextTool" size="large"/>
					<control idMso="LineColorGallery" size="normal"/>
					<!-- Толщина линии (работает в Visio) -->
					<control idMso="LineWeightGallery" size="normal"/>
					<!-- Тип линии (пунктир и т.д.) -->
					<control idMso="LinePatternGallery" size="normal"/>
				</group>
				<group id="MyGroup5" label="Автоматическое соединение">
					<button id="btnAutoConnect" label="Трассировать на слое" size="large" onAction="OnButtonClickPlan" imageMso="ArrowStyleGallery"/>
				</group>
				<group id="MyGroup4" label="Обновить">
					<button id="btnReload" label="Обновить все слои для печати" size="large" onAction="OnButtonClickPlan" imageMso="BuildingBlocksSaveTableOfContents"/>
				</group>
				<group id="MyGroup7" label="Проверка">
					<button id="btnDevicesCheck" label="Диагностика страницы" size="large" onAction="OnButtonClickPlan" imageMso="BuildingBlocksSaveTableOfContents"/>
				</group>
				<group id="MyGroup71" label="Данные">
					<button id="btnGetLineData" label="Генерация кабель-журнала" size="large" onAction="OnButtonClickPlan" imageMso="BuildingBlocksSaveTableOfContents"/>
					<button id="btnSetHyperLinks" label="Назначить ссылки" size="large" onAction="OnButtonClickPlan" imageMso="BuildingBlocksSaveTableOfContents"/>

				</group>
			</tab>

		</tabs>
	</ribbon>
</customUI>